# NarraMeuGol — environment variables (names only; put real values in .env.local)
# See docs/definitions/environment.md

# Google Gemini — video understanding + script generation (@google/genai)
GEMINI_API_KEY=

# ElevenLabs — text-to-speech (@elevenlabs/elevenlabs-js)
ELEVENLABS_API_KEY=
# Voice id. Must be a voice your plan can access — premade voices work on the
# free tier (library/premium voices may require the Creator tier or above).
# Get one in the dashboard: Voices -> (voice) -> Copy Voice ID. Free premade examples:
#   IKne3meq5aSn9XLyUdCD  (Charlie - deep, confident, energetic)
#   TX3LPaxmHKxFdv7VOQHJ  (Liam - energetic)
#   JBFqnCBsd6RMkjVDRZzb  (George - warm storyteller)
ELEVENLABS_VOICE_ID=
